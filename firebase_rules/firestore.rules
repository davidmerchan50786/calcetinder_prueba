rules_version = '2';

// CALCETINDER — Reglas de Firestore
// Principio: ningún dato accesible sin autenticación.
// La seguridad no es opcional aunque la app sea una sátira.

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: solo el propio usuario puede escribirlo; cualquier autenticado puede leerlo
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Calcetines: cualquier autenticado puede ver; solo el propietario puede crear/editar/borrar
    match /socks/{sockId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Swipes: el swiper puede leer los suyos; el dueño del calcetín puede leer
    // swipes sobre sus calcetines (necesario para detectar match mutuo en cliente).
    match /swipes/{swipeId} {
      allow read: if request.auth != null
        && (resource.data.swiperId == request.auth.uid
          || resource.data.sockOwnerId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.swiperId == request.auth.uid
        && request.resource.data.direction in ["like", "nope"];
      // Sin update ni delete — un swipe es inmutable
    }

    // Matches: solo los dos usuarios implicados pueden leer/crear.
    // El create verifica que el usuario autenticado sea uno de los participantes.
    match /matches/{matchId} {
      allow read: if request.auth != null
        && (resource.data.user1Id == request.auth.uid
          || resource.data.user2Id == request.auth.uid);
      allow create: if request.auth != null
        && (request.resource.data.user1Id == request.auth.uid
          || request.resource.data.user2Id == request.auth.uid);
      allow update: if request.auth != null
        && (resource.data.user1Id == request.auth.uid
          || resource.data.user2Id == request.auth.uid);
      allow delete: if false; // los matches son permanentes, como los traumas
    }
  }
}
